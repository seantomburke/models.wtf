{
  "name": "models-wtf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist-server && node scripts/prerender.mjs && node scripts/generate-og-images.mjs && node scripts/generate-sitemap.mjs && node scripts/generate-feed.mjs && node scripts/check-links.mjs && npm run check:bundle-budget",
    "build:node24": "node scripts/run-node24.mjs run build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest",
    "check:agents": "node scripts/check-agent-config.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "validate": "node scripts/validate-data.ts",
    "check:links": "node scripts/check-links.mjs",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opendata-ai/openchart-react": "^7.9.2",
    "@posthog/react": "^1.10.3",
    "@tailwindcss/vite": "^4.3.2",
    "gpt-tokenizer": "^3.4.0",
    "katex": "^0.18.1",
    "posthog-js": "^1.406.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  }
}
